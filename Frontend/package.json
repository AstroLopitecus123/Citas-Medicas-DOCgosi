{
  "name": "frontend-citas",
  "version": "0.0.0",
  "engines": {
    "node": "^20.11.0 || ^22.0.0"
  },
  "scripts": {
    "ng": "ng",
    "start": "node server.js",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:a11y": "cypress open",
    "test:a11y:headless": "cypress run"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
