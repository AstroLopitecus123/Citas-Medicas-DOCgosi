{
  "name": "frontend-citas",
  "version": "0.0.0",
  "engines": {
    "node": "^20.11.0 || ^22.0.0"
  },
  "scripts": {
    "ng": "ng",
    "start": "npx -y serve -s browser -l $PORT",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
