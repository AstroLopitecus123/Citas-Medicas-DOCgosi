      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "dependencies": {
    "@angular/common": "~19.1.0",
    "@angular/compiler": "~19.1.0",
    "@angular/core": "~19.1.0",
    "@angular/forms": "~19.1.0",
    "@angular/platform-browser": "~19.1.0",
    "@angular/router": "~19.1.0",
    "@deepgram/sdk": "^5.0.0",
    "@stripe/stripe-js": "^9.2.0",
    "agora-rtc-sdk-ng": "^4.24.3",
    "express": "^4.18.2",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "leaflet": "^1.9.4",
    "ngx-image-cropper": "^9.1.6",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular/build": "~19.1.0",
    "@angular/cli": "~19.1.0",
    "@angular/compiler-cli": "~19.1.0",
